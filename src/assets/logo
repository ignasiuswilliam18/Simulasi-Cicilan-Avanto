import React from 'react';
import { HP_PRODUCTS, IOT_PRODUCTS, OPPO_CARE_PRODUCTS, ProductItem } from '../../../Data';

interface SelectorProps {
  selectedHp: ProductItem;
  setSelectedHp: (product: ProductItem) => void;
  selectedIot: ProductItem;
  setSelectedIot: (product: ProductItem) => void;
  selectedOppoCare: ProductItem;
  setSelectedOppoCare: (product: ProductItem) => void;
}

export const Selector: React.FC<SelectorProps> = ({
  selectedHp,
  setSelectedHp,
  selectedIot,
  setSelectedIot,
  selectedOppoCare,
  setSelectedOppoCare,
}) => {
  return (
    <div className="w-full bg-neutral-900 border border-neutral-800 p-6 rounded-2xl flex flex-col gap-6">
      <div>
        <h2 className="text-xl font-bold text-white">Pilih Produk</h2>
        <p className="text-sm text-neutral-400">Silakan pilih kombinasi produk untuk simulasi cicilan Avanto</p>
      </div>

      <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
        {/* 1. Selector HP */}
        <div className="flex flex-col gap-2">
          <label className="text-sm font-semibold text-neutral-300">Tipe HP OPPO</label>
          <select
            value={selectedHp.model}
            onChange={(e) => {
              const prod = HP_PRODUCTS.find((p) => p.model === e.target.value);
              if (prod) setSelectedHp(prod);
            }}
            className="w-full bg-neutral-950 border border-neutral-800 text-white rounded-xl p-3 text-sm outline-none focus:border-emerald-500 transition-colors cursor-pointer"
          >
            {HP_PRODUCTS.map((hp) => (
              <option key={hp.model} value={hp.model}>
                {hp.model} {hp.price > 0 ? `- Rp ${hp.price.toLocaleString('id-ID')}` : ''}
              </option>
            ))}
          </select>
        </div>

        {/* 2. Selector IOT */}
        <div className="flex flex-col gap-2">
          <label className="text-sm font-semibold text-neutral-300">Perangkat IOT</label>
          <select
            value={selectedIot.model}
            onChange={(e) => {
              const prod = IOT_PRODUCTS.find((p) => p.model === e.target.value);
              if (prod) setSelectedIot(prod);
            }}
            className="w-full bg-neutral-950 border border-neutral-800 text-white rounded-xl p-3 text-sm outline-none focus:border-emerald-500 transition-colors cursor-pointer"
          >
            {IOT_PRODUCTS.map((iot) => (
              <option key={iot.model} value={iot.model}>
                {iot.model} {iot.price > 0 ? `- Rp ${iot.price.toLocaleString('id-ID')}` : ''}
              </option>
            ))}
          </select>
        </div>

        {/* 3. Selector OPPO Care */}
        <div className="flex flex-col gap-2">
          <label className="text-sm font-semibold text-neutral-300">Paket Perlindungan OPPO Care</label>
          <select
            value={selectedOppoCare.model}
            onChange={(e) => {
              const prod = OPPO_CARE_PRODUCTS.find((p) => p.model === e.target.value);
              if (prod) setSelectedOppoCare(prod);
            }}
            className="w-full bg-neutral-950 border border-neutral-800 text-white rounded-xl p-3 text-sm outline-none focus:border-emerald-500 transition-colors cursor-pointer"
          >
            {OPPO_CARE_PRODUCTS.map((oc) => (
              <option key={oc.model} value={oc.model}>
                {oc.model} {oc.price > 0 ? `- Rp ${oc.price.toLocaleString('id-ID')}` : ''}
              </option>
            ))}
          </select>
        </div>
      </div>
    </div>
  );
};

export default Selector;